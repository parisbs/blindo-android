<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/appIcon"
        android:layout_width="@dimen/app_icon_width_height"
        android:layout_height="@dimen/app_icon_width_height"
        android:layout_marginVertical="@dimen/activity_vertical_margin"
        android:layout_marginEnd="@dimen/default_components_margin"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <LinearLayout
        android:id="@+id/appHeaderContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@id/appIcon"
        app:layout_constraintStart_toEndOf="@id/appIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/appRating">

        <TextView
            android:id="@+id/appLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/default_components_margin"
            android:gravity="start"
            android:ellipsize="marquee"
            />

        <TextView
            android:id="@+id/appCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/default_components_margin"
            android:gravity="start"
            android:ellipsize="marquee"
            />

    </LinearLayout>

    <TextView
        android:id="@+id/appRating"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/default_components_margin"
        android:gravity="start"
        android:ellipsize="marquee"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/appHeaderContainer"
        app:layout_constraintStart_toEndOf="@id/appIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/appPacks"
        />

    <TextView
        android:id="@+id/appPacks"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/default_components_margin"
        android:gravity="start"
        android:ellipsize="marquee"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/appRating"
        app:layout_constraintStart_toEndOf="@id/appIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
