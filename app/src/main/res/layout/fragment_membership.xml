<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.membership.MembershipFragment">

    <TextView
        android:id="@+id/currentSubscription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/activity_vertical_margin"
        android:layout_marginStart="@dimen/activity_horizontal_margin"
        app:layout_goneMarginBottom="@dimen/activity_vertical_margin"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/changeSubscription"
        />

    <ImageButton
        android:id="@+id/changeSubscription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/activity_vertical_margin"
        android:layout_marginStart="@dimen/default_components_margin"
        android:layout_marginEnd="@dimen/activity_horizontal_margin"
        app:layout_goneMarginBottom="@dimen/activity_vertical_margin"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/currentSubscriptionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:constraint_referenced_ids="currentSubscription,changeSubscription"
        />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/currentSubscriptionHeaderBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="true"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="currentSubscription,changeSubscription"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/subscriptionsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/activity_horizontal_margin"
        android:scrollbars="vertical"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/currentSubscriptionHeaderBarrier"
        app:layout_constraintBottom_toTopOf="@id/subscriptionNotice"
        />

    <TextView
        android:id="@+id/subscriptionNotice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/default_components_margin"
        android:layout_marginHorizontal="@dimen/activity_horizontal_margin"
        android:singleLine="false"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/actionsBarrier"
        />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/actionsBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="manageSubscription,subscribeNow"
        />

    <Button
        android:id="@+id/manageSubscription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/default_components_margin"
        android:layout_marginStart="@dimen/activity_horizontal_margin"
        android:layout_marginBottom="@dimen/activity_vertical_margin"
        android:text="@string/membership__manage_subscription"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/subscribeNow"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <Button
        android:id="@+id/subscribeNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/default_components_margin"
        android:layout_marginStart="@dimen/default_components_margin"
        android:layout_marginEnd="@dimen/activity_horizontal_margin"
        android:layout_marginBottom="@dimen/activity_vertical_margin"
        android:text="@string/membership__subscribe_now"
        app:layout_constraintStart_toEndOf="@id/manageSubscription"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
