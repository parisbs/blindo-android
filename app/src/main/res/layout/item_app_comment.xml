<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/appCommentUserPicture"
        android:layout_width="@dimen/userpicture_size"
        android:layout_height="@dimen/userpicture_size"
        android:layout_margin="@dimen/default_components_margin"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/commentHeaderContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@id/appCommentUserPicture"
        app:layout_constraintStart_toEndOf="@id/appCommentUserPicture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/appCommentText">

        <TextView
            android:id="@+id/appCommentUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/default_components_margin"
            android:gravity="start"
            android:singleLine="true"
            android:ellipsize="marquee" />

        <TextView
            android:id="@+id/appCommentTotalAndDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/default_components_margin"
            android:gravity="start" />

    </LinearLayout>

    <TextView
        android:id="@+id/appCommentText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/default_components_margin"
        android:gravity="start|center_vertical"
        android:singleLine="false"
        android:maxLines="2"
        android:ellipsize="end"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/commentHeaderContainer"
        app:layout_constraintStart_toEndOf="@id/appCommentUserPicture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/appCommentUserPicture" />

</androidx.constraintlayout.widget.ConstraintLayout>
