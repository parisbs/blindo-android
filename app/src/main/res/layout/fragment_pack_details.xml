<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.pack.details.PackDetailsFragment">

    <ImageView
        android:id="@+id/userPhoto"
        android:layout_width="@dimen/userpicture_size"
        android:layout_height="@dimen/userpicture_size"
        android:layout_margin="@dimen/default_components_margin"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/authorInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/default_components_margin"
        android:layout_marginHorizontal="@dimen/default_components_margin"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="marquee"
        app:layout_constraintTop_toTopOf="@id/userPhoto"
        app:layout_constraintStart_toEndOf="@id/userPhoto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dateInfo" />

    <TextView
        android:id="@+id/dateInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginHorizontal="@dimen/default_components_margin"
        android:layout_marginBottom="@dimen/default_components_margin"
        android:singleLine="true"
        android:ellipsize="marquee"
        app:layout_constraintTop_toBottomOf="@id/authorInfo"
        app:layout_constraintStart_toEndOf="@id/userPhoto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/userPhoto" />

    <TextView
        android:id="@+id/downloadInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        app:layout_constraintTop_toBottomOf="@id/userPhoto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/labelsInfo" />

    <TextView
        android:id="@+id/labelsInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        app:layout_constraintTop_toBottomOf="@id/downloadInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/installPack" />

    <CheckBox
        android:id="@+id/translateCheckBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        android:checked="false"
        app:layout_constraintTop_toTopOf="@id/labelsInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/translateCheckLabel"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/translateCheckLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        android:labelFor="@id/translateCheckBox"
        app:layout_constraintTop_toTopOf="@id/labelsInfo"
        app:layout_constraintStart_toEndOf="@id/translateCheckBox"
        app:layout_constraintEnd_toStartOf="@id/installPack"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/installPack"
        android:layout_width="@dimen/default_icon_size"
        android:layout_height="@dimen/default_icon_size"
        android:layout_margin="@dimen/default_components_margin"
        android:contentDescription="@string/packdetails__install_button"
        android:src="@drawable/ic_cloud_download_black_24dp"
        app:layout_constraintTop_toBottomOf="@id/labelsInfo"
        app:layout_constraintStart_toEndOf="@id/translateCheckLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
