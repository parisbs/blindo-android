<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/nav_header_height"
    android:background="@drawable/side_nav_bar"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:theme="@style/ThemeOverlay.AppCompat.Dark"
    tools:viewBindingIgnore="true">

    <TextView
        android:id="@+id/signIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/activity_vertical_margin"
        android:layout_marginHorizontal="@dimen/activity_horizontal_margin"
        android:clickable="true"
        android:visibility="gone"
        android:text="@string/header__sign_in"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/userPicture"
        android:layout_width="@dimen/userpicture_size"
        android:layout_height="@dimen/userpicture_size"
        android:layout_margin="@dimen/default_components_margin"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/userCrown"
        android:layout_width="@dimen/crown_width"
        android:layout_height="@dimen/crown_height"
        android:layout_marginTop="@dimen/minimum"
        android:layout_marginStart="@dimen/default_components_margin"
        android:contentDescription="@string/header__premium_crown"
        android:src="@drawable/ic_crown"
        app:layout_constraintTop_toTopOf="@id/userName"
        app:layout_constraintStart_toEndOf="@id/userPicture"
        app:layout_constraintEnd_toStartOf="@id/userName" />

    <TextView
        android:id="@+id/userName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        android:gravity="center"
        android:clickable="true"
        android:singleLine="true"
        android:ellipsize="marquee"
        app:layout_constraintTop_toTopOf="@id/userPicture"
        app:layout_constraintStart_toEndOf="@id/userCrown"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/userProfile" />

    <TextView
        android:id="@+id/userProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        android:gravity="center"
        android:clickable="true"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:text="@string/header__user_profile"
        app:layout_constraintTop_toBottomOf="@id/userName"
        app:layout_constraintStart_toEndOf="@id/userPicture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/signOut" />

    <TextView
        android:id="@+id/signOut"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_components_margin"
        android:gravity="center"
        android:clickable="true"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:text="@string/header__signout"
        app:layout_constraintTop_toBottomOf="@id/userProfile"
        app:layout_constraintStart_toEndOf="@id/userPicture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/userPicture" />

</androidx.constraintlayout.widget.ConstraintLayout>
